# OpenSearch configuration
OPENSEARCH_HOST=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX=graphfusion_chunks

# Neo4j configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Application configuration
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
# Azure OpenAI LLM configuration
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Azure OpenAI Embeddings configuration
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large

# Image extraction mode: "ocr" (pytesseract) or "vlm" (Azure OpenAI vision)
IMAGE_EXTRACTION_MODE=ocr

# Azure OpenAI Vision configuration (only if IMAGE_EXTRACTION_MODE=vlm)
AZURE_OPENAI_VISION_MODEL=gpt-4o

# Optional: Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Optional: CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000